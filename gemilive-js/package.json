{
  "name": "gemilive-js",
  "version": "0.1.2",
  "description": "Browser SDK for the gemilive Gemini Live AI proxy — real-time voice & video with minimal setup.",
  "main": "src/index.js",
  "module": "src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./src/index.js",
      "browser": "./src/index.js"
    }
  },
  "files": [
    "src/",
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "npx esbuild src/index.js --bundle --minify --format=iife --outfile=dist/gemilive.min.js",
    "dev": "npx esbuild src/index.js --bundle --format=iife --outfile=dist/gemilive.js --watch"
  },
  "keywords": [
    "gemini",
    "live",
    "ai",
    "voice",
    "video",
    "websocket",
    "realtime"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saidurpulok/gemilive.git"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.20.0"
  }
}